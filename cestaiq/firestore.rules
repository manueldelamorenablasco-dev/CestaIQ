rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: solo puede leer/escribir su propio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Productos: lectura pública, escritura solo admin
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if false; // solo desde Firebase Console o Admin SDK
    }

    // Supermercados: lectura pública
    match /supermarkets/{supermarketId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Precios: lectura pública
    match /prices/{priceId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Cestas: solo el propietario
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
